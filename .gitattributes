# Normalize all text to LF in the repo so shell hooks + python scripts run on
# Linux/macOS regardless of the committer's platform (Windows CRLF would break
# the #!/bin/sh shebangs on the git hook scripts).
* text=auto eol=lf

# Belt-and-suspenders for the executable scripts (no extension / shell / python)
plugins/engram/hooks/git/pre-commit text eol=lf
plugins/engram/hooks/git/commit-msg text eol=lf
plugins/engram/hooks/git/pre-push  text eol=lf
*.sh  text eol=lf
*.py  text eol=lf
